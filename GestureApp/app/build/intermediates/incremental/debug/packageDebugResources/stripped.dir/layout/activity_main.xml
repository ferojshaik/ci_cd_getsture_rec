<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F1F5F9"
    android:fitsSystemWindows="true">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#0D9488"
        android:elevation="4dp"
        app:elevation="4dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="#0D9488"
            android:minHeight="56dp"
            app:title="@string/app_name"
            app:titleTextColor="#FFFFFF"
            app:titleTextAppearance="@style/TextAppearance.Toolbar" />
    </com.google.android.material.appbar.AppBarLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:overScrollMode="never"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp"
            android:gravity="center_horizontal"
            android:background="#F1F5F9">

            <!-- Hero card: current gesture -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="24dp"
                app:cardElevation="6dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:paddingStart="24dp"
                    android:paddingEnd="24dp"
                    android:paddingTop="40dp"
                    android:paddingBottom="40dp"
                    android:minHeight="200dp">

                    <TextView
                        android:id="@+id/label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/listening"
                        android:textColor="#64748B"
                        android:textSize="36sp"
                        android:letterSpacing="0.02"
                        android:fontFamily="sans-serif-medium"
                        android:contentDescription="@string/current_gesture" />

                    <TextView
                        android:id="@+id/subtitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="@string/subtitle"
                        android:textColor="#94A3B8"
                        android:textSize="14sp"
                        android:gravity="center"
                        android:lineSpacingExtra="2dp"
                        android:maxWidth="280dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Recognized gestures section -->
            <TextView
                android:id="@+id/hint_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:text="@string/hint"
                android:textColor="#475569"
                android:textSize="13sp"
                android:letterSpacing="0.05"
                android:fontFamily="sans-serif-medium" />

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/chip_group"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:singleSelection="true"
                app:selectionRequired="false"
                app:chipSpacingHorizontal="8dp"
                app:chipSpacingVertical="8dp">

                <com.google.android.material.chip.Chip
                    android:id="@+id/tap_chip"
                    style="@style/Widget.MaterialComponents.Chip.Choice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/tap"
                    android:clickable="false"
                    android:focusable="false"
                    app:chipBackgroundColor="#F1F5F9"
                    app:chipStrokeColor="#CBD5E1"
                    app:chipStrokeWidth="1dp"
                    app:chipMinHeight="44dp"
                    app:chipCornerRadius="22dp" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/wave_chip"
                    style="@style/Widget.MaterialComponents.Chip.Choice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/wave"
                    android:clickable="false"
                    android:focusable="false"
                    app:chipBackgroundColor="#F1F5F9"
                    app:chipStrokeColor="#CBD5E1"
                    app:chipStrokeWidth="1dp"
                    app:chipMinHeight="44dp"
                    app:chipCornerRadius="22dp" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/shake_chip"
                    style="@style/Widget.MaterialComponents.Chip.Choice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/shake"
                    android:clickable="false"
                    android:focusable="false"
                    app:chipBackgroundColor="#F1F5F9"
                    app:chipStrokeColor="#CBD5E1"
                    app:chipStrokeWidth="1dp"
                    app:chipMinHeight="44dp"
                    app:chipCornerRadius="22dp" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/idle_chip"
                    style="@style/Widget.MaterialComponents.Chip.Choice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/idle"
                    android:clickable="false"
                    android:focusable="false"
                    app:chipBackgroundColor="#F1F5F9"
                    app:chipStrokeColor="#CBD5E1"
                    app:chipStrokeWidth="1dp"
                    app:chipMinHeight="44dp"
                    app:chipCornerRadius="22dp" />
            </com.google.android.material.chip.ChipGroup>

            <!-- Status -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:layout_marginBottom="24dp"
                android:gravity="center"
                android:orientation="horizontal">

                <View
                    android:id="@+id/status_dot"
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:background="@drawable/status_dot" />
                <TextView
                    android:id="@+id/status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="@string/status_active"
                    android:textColor="#94A3B8"
                    android:textSize="13sp" />
            </LinearLayout>
            <TextView
                android:id="@+id/model_version"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:textColor="#64748B"
                android:textSize="12sp"
                android:text="@string/model_version_bundled" />
        </LinearLayout>
    </ScrollView>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
